{
	"name": "exam-b3-reverse-engineering-ui",
	"version": "1.0.0",
	"description": "Starter kit d'examen B3 — Reverse Engineering UI",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"check": "biome check --write .",
		"lint": "biome ci .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"validate": "biome ci . && tsc --noEmit && next build"
	},
	"packageManager": "bun@1.3.14",
	"dependencies": {
		"next": "15.5.20",
		"react": "19.2.7",
		"react-dom": "19.2.7"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@tailwindcss/postcss": "4.3.2",
		"@types/node": "26.1.0",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"postcss": "8.5.16",
		"tailwindcss": "4.3.2",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
